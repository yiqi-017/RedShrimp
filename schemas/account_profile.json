{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RedShrimp Account Profile",
  "description": "账号画像结构，用于 RedShrimp 在 generate_post_plan、pre_publish_review、postmortem 等任务中判断账号阶段、内容方向与约束条件。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "account_id",
    "platform",
    "profile_snapshot_at",
    "nickname",
    "bio",
    "follower_count",
    "following_count",
    "total_liked_count",
    "post_count",
    "account_stage",
    "primary_categories",
    "target_audience",
    "content_formats",
    "brand_tone",
    "growth_goal"
  ],
  "properties": {
    "account_id": {
      "type": "string",
      "description": "账号唯一标识；可使用站内 ID、主页链接片段或 GA 自定义主键。",
      "examples": ["xhs_account_001"]
    },
    "platform": {
      "type": "string",
      "enum": ["xiaohongshu"],
      "description": "当前平台，第一阶段固定为小红书。"
    },
    "profile_snapshot_at": {
      "type": "string",
      "format": "date-time",
      "description": "账号画像采集时间，用于和策略输出、发后结果对齐。",
      "examples": ["2025-08-10T21:00:00Z"]
    },
    "nickname": {
      "type": "string",
      "minLength": 1,
      "description": "账号昵称。",
      "examples": ["阿青的通勤穿搭"]
    },
    "bio": {
      "type": "string",
      "description": "主页简介；没有时可传空字符串。",
      "examples": ["分享150-300元也能穿得像样的上班穿搭"]
    },
    "follower_count": {
      "type": "integer",
      "minimum": 0,
      "description": "粉丝数。",
      "examples": [3240]
    },
    "following_count": {
      "type": "integer",
      "minimum": 0,
      "description": "关注数。",
      "examples": [186]
    },
    "total_liked_count": {
      "type": "integer",
      "minimum": 0,
      "description": "账号主页可见的累计获赞与收藏或近似热度指标；若平台展示口径变化，应在 notes 中注明。",
      "examples": [15800]
    },
    "post_count": {
      "type": "integer",
      "minimum": 0,
      "description": "已发布笔记数。",
      "examples": [47]
    },
    "account_stage": {
      "type": "string",
      "enum": ["new", "early", "growing", "mature", "reactivation"],
      "description": "账号阶段，用于判断策略激进程度。"
    },
    "primary_categories": {
      "type": "array",
      "description": "账号主内容赛道，可多选。",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "examples": [["fashion", "commute_outfit"]]
    },
    "secondary_categories": {
      "type": "array",
      "description": "可扩展副赛道。",
      "items": {
        "type": "string"
      },
      "examples": [["student_style", "budget_buy"]]
    },
    "target_audience": {
      "type": "array",
      "description": "目标受众标签。",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "examples": [["female_office_workers", "college_students"]]
    },
    "content_formats": {
      "type": "array",
      "description": "当前账号常用或允许的内容形式。",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["image_text", "video", "mixed"]
      },
      "examples": [["image_text"]]
    },
    "brand_tone": {
      "type": "array",
      "description": "账号表达风格。",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "examples": [["practical", "friendly", "budget_sensitive"]]
    },
    "growth_goal": {
      "type": "string",
      "enum": [
        "increase_followers",
        "increase_engagement",
        "increase_exposure",
        "improve_conversion",
        "test_new_topic"
      ],
      "description": "当前阶段主要增长目标。"
    },
    "strengths": {
      "type": "array",
      "description": "账号已知优势，如真人出镜、选品能力、故事感等。",
      "items": {
        "type": "string"
      },
      "examples": [["真人实拍", "价格敏感度强", "标题具体"]]
    },
    "weaknesses": {
      "type": "array",
      "description": "账号已知短板。",
      "items": {
        "type": "string"
      },
      "examples": [["封面统一性弱", "缺少系列化选题"]]
    },
    "content_do": {
      "type": "array",
      "description": "建议坚持的内容边界或做法。",
      "items": {
        "type": "string"
      },
      "examples": [["优先做真实通勤场景", "标题保留价格锚点"]]
    },
    "content_dont": {
      "type": "array",
      "description": "不建议触碰的内容边界。",
      "items": {
        "type": "string"
      },
      "examples": [["不过度夸张承诺", "不直接照搬他人封面文案"]]
    },
    "posting_frequency": {
      "type": "string",
      "description": "当前发帖频率描述。",
      "examples": ["3 posts per week"]
    },
    "preferred_publish_windows": {
      "type": "array",
      "description": "历史上相对适合的发布时间窗口。",
      "items": {
        "type": "string"
      },
      "examples": [["07:30-08:30", "21:00-22:30"]]
    },
    "recent_content_summary": {
      "type": "string",
      "description": "近期内容总体概述，便于策略模块快速理解近况。",
      "examples": ["最近 10 条以平价通勤穿搭为主，学生党开学相关内容互动略高。"]
    },
    "risk_flags": {
      "type": "array",
      "description": "账号风险标记，如同质化、更新停滞、违规敏感等。",
      "items": {
        "type": "string"
      },
      "examples": [["topic_homogenization", "low_cover_consistency"]]
    },
    "notes": {
      "type": "array",
      "description": "补充说明。",
      "items": {
        "type": "string"
      },
      "examples": [["total_liked_count 为主页展示口径估算值"]]
    }
  },
  "examples": [
    {
      "account_id": "xhs_account_001",
      "platform": "xiaohongshu",
      "profile_snapshot_at": "2025-08-10T21:00:00Z",
      "nickname": "阿青的通勤穿搭",
      "bio": "分享150-300元也能穿得像样的上班穿搭",
      "follower_count": 3240,
      "following_count": 186,
      "total_liked_count": 15800,
      "post_count": 47,
      "account_stage": "growing",
      "primary_categories": ["fashion", "commute_outfit"],
      "secondary_categories": ["student_style", "budget_buy"],
      "target_audience": ["female_office_workers", "college_students"],
      "content_formats": ["image_text"],
      "brand_tone": ["practical", "friendly", "budget_sensitive"],
      "growth_goal": "increase_followers",
      "strengths": ["真人实拍", "价格敏感度强", "标题具体"],
      "weaknesses": ["封面统一性弱", "缺少系列化选题"],
      "content_do": ["优先做真实通勤场景", "标题保留价格锚点"],
      "content_dont": ["不过度夸张承诺", "不直接照搬他人封面文案"],
      "posting_frequency": "3 posts per week",
      "preferred_publish_windows": ["07:30-08:30", "21:00-22:30"],
      "recent_content_summary": "最近 10 条以平价通勤穿搭为主，学生党开学相关内容互动略高。",
      "risk_flags": ["topic_homogenization", "low_cover_consistency"],
      "notes": ["total_liked_count 为主页展示口径估算值"]
    }
  ]
}