{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RedShrimp Strategy Output",
  "description": "RedShrimp 各任务统一策略输出结构，供 GenericAgent 稳定消费 decision、评分、原因、风险与任务专属结果。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task",
    "decision",
    "summary",
    "risk_alerts",
    "scores",
    "why",
    "next_actions",
    "task_specific_payload"
  ],
  "properties": {
    "task": {
      "type": "string",
      "enum": [
        "analyze_viral_post",
        "generate_post_plan",
        "pre_publish_review",
        "postmortem"
      ],
      "description": "当前输出对应的任务名，需与输入 task 保持一致。"
    },
    "decision": {
      "type": "string",
      "enum": ["publish", "revise", "skip"],
      "description": "最终动作建议。publish=可推进；revise=需先改；skip=当前不建议做。"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "一句话说明本次策略结论。"
    },
    "risk_alerts": {
      "type": "array",
      "description": "风险提示列表；没有风险时返回空数组。",
      "items": {
        "type": "string"
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic_potential", "fit_account", "novelty", "risk"],
      "properties": {
        "topic_potential": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "主题潜力评分。"
        },
        "fit_account": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "与当前账号匹配度评分。"
        },
        "novelty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "新颖度评分。"
        },
        "risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "风险评分；越高代表风险越大。"
        },
        "execution_complexity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "执行复杂度，可选。"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "综合判断置信度，可选。"
        }
      }
    },
    "why": {
      "type": "array",
      "description": "支撑 decision 的关键原因列表。",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "description": "GenericAgent 可继续执行的明确动作列表。",
      "items": {
        "type": "string"
      }
    },
    "must_fix": {
      "type": "array",
      "description": "当 decision=revise 时的必改项；其它情况可省略或为空。",
      "items": {
        "type": "string"
      }
    },
    "task_specific_payload": {
      "type": "object",
      "description": "任务专属结果体。字段随 task 变化，但建议保持结构化、避免大段自由文本。",
      "additionalProperties": true,
      "properties": {
        "recommended_topic": {
          "type": "string",
          "description": "建议选题。常见于 generate_post_plan。"
        },
        "angle": {
          "type": "string",
          "description": "切入角度。"
        },
        "title_candidates": {
          "type": "array",
          "items": { "type": "string" },
          "description": "标题候选。"
        },
        "cover_direction": {
          "type": "array",
          "items": { "type": "string" },
          "description": "封面方向建议。"
        },
        "body_structure": {
          "type": "array",
          "items": { "type": "string" },
          "description": "正文结构建议。"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "建议标签。"
        },
        "publish_window": {
          "type": "string",
          "description": "建议发布时间窗口。"
        },
        "viral_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "爆款模式提炼。常见于 analyze_viral_post。"
        },
        "do_not_copy": {
          "type": "array",
          "items": { "type": "string" },
          "description": "不可直接照搬部分。"
        },
        "keep_factors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "复盘中建议保留的因素。"
        },
        "drop_factors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "复盘中建议舍弃的因素。"
        },
        "next_test_directions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "下一轮测试方向。"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": { "const": "revise" }
        },
        "required": ["decision"]
      },
      "then": {
        "required": ["must_fix"]
      }
    }
  ],
  "examples": [
    {
      "task": "generate_post_plan",
      "decision": "publish",
      "summary": "建议围绕开学前平价通勤穿搭做一篇可立即执行的图文笔记。",
      "risk_alerts": [],
      "scores": {
        "topic_potential": 0.81,
        "fit_account": 0.76,
        "novelty": 0.62,
        "risk": 0.18,
        "execution_complexity": 0.34,
        "confidence": 0.79
      },
      "why": [
        "近期通勤与开学场景需求稳定，且价格锚点内容持续有收藏倾向。",
        "该主题与账号现有平价穿搭定位一致，受众理解成本低。"
      ],
      "next_actions": [
        "优先从标题候选中选择最具体的一版。",
        "封面突出一周场景和价格锚点。"
      ],
      "task_specific_payload": {
        "recommended_topic": "开学前一周平价通勤穿搭",
        "angle": "用150-300元预算解决学生和初入职场女生的一周通勤穿搭",
        "title_candidates": [
          "打工人/学生党都能抄的一周通勤穿搭，300元内搞定",
          "开学前先把通勤穿搭准备好：这套平价公式真的省心"
        ],
        "cover_direction": [
          "封面用一周搭配九宫格",
          "价格数字做大，突出300元内"
        ],
        "body_structure": [
          "场景拆分",
          "单套展示",
          "价格说明",
          "购买建议"
        ],
        "tags": ["通勤穿搭", "平价穿搭", "学生党穿搭"],
        "publish_window": "21:00-22:30"
      }
    },
    {
      "task": "pre_publish_review",
      "decision": "revise",
      "summary": "草稿方向可用，但封面承诺偏泛、正文缺少价格锚点，建议修改后再发。",
      "risk_alerts": ["标题不够具体", "封面信息密度不足"],
      "scores": {
        "topic_potential": 0.68,
        "fit_account": 0.74,
        "novelty": 0.49,
        "risk": 0.41
      },
      "why": [
        "主题与账号方向一致，但表达颗粒度不足，可能影响点击和收藏。",
        "当前草稿缺少核心实用信息，难以形成明显差异化。"
      ],
      "next_actions": [
        "重写标题，加入具体预算或场景词。",
        "补充每套穿搭的价格信息。"
      ],
      "must_fix": [
        "封面加入预算锚点",
        "正文每套穿搭补充价格和适用场景"
      ],
      "task_specific_payload": {
        "cover_direction": ["增加预算数字", "强调一周通勤场景"],
        "body_structure": ["先总览", "再按场景拆解", "结尾给购买建议"]
      }
    }
  ]
}